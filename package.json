{
    "name": "remote-control",
    "version": "1.0.0",
    "description": "Remote desktop control system with Rust backend and web frontend",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "pnpm typecheck && vite build",
        "preview": "vite preview",
        "typecheck": "tsc -b --noEmit",
        "lint": "oxlint",
        "lint:fix": "oxlint --fix",
        "tlint": "oxlint --type-aware",
        "format": "oxfmt",
        "format:check": "oxfmt --check"
    },
    "dependencies": {
        "@xterm/addon-fit": "^0.11.0",
        "@xterm/addon-web-links": "^0.12.0",
        "@xterm/xterm": "^6.0.0",
        "socket.io-client": "^4.8.3"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.3.2",
        "@types/node": "^26.1.1",
        "oxfmt": "^0.59.0",
        "oxlint": "^1.74.0",
        "oxlint-tsgolint": "^0.24.0",
        "typescript": "^7.0.2",
        "vite": "^8.1.4"
    }
}
